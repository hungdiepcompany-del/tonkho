{
  "schemaVersion": "SGDS_D6C_D6E_LOCAL_ADAPTERS_V1",
  "fixturePolicy": {
    "realPrivateContent": false,
    "rawAttachmentBytes": false,
    "productionGoogleApi": false,
    "productionFirestore": false
  },
  "cases": [
    {
      "id": "invoice_pdf_email",
      "description": "Invoice email with XML and PDF evidence",
      "expectedClassification": "invoice",
      "message": {
        "gmailMessageId": "msg-fixture-001",
        "threadId": "thread-fixture-001",
        "from": "Supplier One <supplier.one@example.test>",
        "to": ["accounting@example.test"],
        "subject": "Sanitized HDDT invoice",
        "receivedAt": "2026-02-01T03:26:41.000Z",
        "attachments": [
          {
            "attachmentId": "att-001-xml",
            "fileName": "invoice-001.xml",
            "mimeType": "application/xml",
            "sizeBytes": 1200,
            "expectedSha256": "sha256_fixture_invoice_001_xml"
          },
          {
            "attachmentId": "att-001-pdf",
            "fileName": "invoice-001.pdf",
            "mimeType": "application/pdf",
            "sizeBytes": 2200,
            "expectedSha256": "sha256_fixture_invoice_001_pdf"
          }
        ]
      }
    },
    {
      "id": "quotation_excel_email",
      "description": "Quotation spreadsheet",
      "expectedClassification": "quotation",
      "message": {
        "gmailMessageId": "msg-fixture-002",
        "threadId": "thread-fixture-002",
        "from": "sales@example.test",
        "to": ["purchasing@example.test"],
        "subject": "Quotation for material",
        "receivedAt": "2026-02-02T01:00:00.000Z",
        "attachments": [
          {
            "attachmentId": "att-002-xlsx",
            "fileName": "quotation.xlsx",
            "mimeType": "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
            "sizeBytes": 4096,
            "expectedSha256": "sha256_fixture_quotation_xlsx"
          }
        ]
      }
    },
    {
