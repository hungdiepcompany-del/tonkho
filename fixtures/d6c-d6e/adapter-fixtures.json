        "gmailMessageId": "msg-fixture-003",
        "threadId": "thread-fixture-003",
        "from": "source@example.test",
        "to": ["accounting@example.test"],
        "subject": "Two sanitized attachments",
        "receivedAt": "2026-02-03",
        "attachments": [
          {
            "attachmentId": "att-003-a",
